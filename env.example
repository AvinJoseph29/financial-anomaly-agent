# ── LLM ───────────────────────────────────────────────────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=

# Model — Llama 3.1 70B is free on Groq and beats GPT-3.5 on finance tasks
GROQ_MODEL=llama-3.1-70b-versatile

# Embedding model (runs locally, no key needed)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Neo4j (Neo4j Desktop — local) ─────────────────────────────────────────────
# After installing Neo4j Desktop: create a project → create DB → start it
# Default bolt port is 7687, default password is what you set on first run
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ── Qdrant (local file mode — no server needed) ───────────────────────────────
# Leave blank to use in-memory mode. Set a path to persist across runs.
QDRANT_PATH=./data/qdrant_store

# ── Optional: Tavily web search (free tier — 1000 calls/month) ────────────────
# Get key at: https://tavily.com
TAVILY_API_KEY=your_tavily_key_here

# ── Paths ─────────────────────────────────────────────────────────────────────
RAW_FILINGS_DIR=./data/raw_filings
PROCESSED_DIR=./data/processed
CACHE_DIR=./data/cache
